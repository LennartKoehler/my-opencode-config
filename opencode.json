{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@mohak34/opencode-notifier@latest"
  ],
  "default_agent": "build",
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local",
      "options": {
        "baseURL": "{env:LOCAL_LLM_URL}",
        "apiKey": "{env:LOCAL_LLM_API_KEY}"
      },
      "models": {
        "vllm/frontier": {
          "name": "frontier",
          "limit": {
                "context": 200000,
                "output": 60000
          }
        },
        "vllm/coder": {
          "name": "coder",
          "limit": {
                "context": 128000,
                "output": 60000
          }
        }
      }
    }
  },
  "model": "local/vllm/frontier",
  "permission": {
    "*": "ask",


    "skill": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",

    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "deny",

    "task": "allow",

    "external_directory": {
      "*": "ask"
    },

    "edit": {
      "*": "ask",
      "*.cpp": "allow",
      "*.py": "allow",
      "*.h": "allow",
      "*.cu": "allow",
      "*.cuh": "allow",
      "*.txt": "allow",

      "*.md": "allow",
      "*.mdx": "allow",
      "*.json": "allow",
      "*.yaml": "allow",
      "*.yml": "allow"
    },

    "bash": {
      "*": "ask",

      "rg*": "allow",
      "ls*": "allow",
      "echo*": "allow",
      "sed*": "allow",
      "head*": "allow",
      "mkdir*": "allow",
      "cd*": "allow",
      "find*": "allow",
      "file*": "allow",

      "git status*": "allow",
      "git ls-tree*": "allow",
      "git show*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",

      "npm run lint*": "allow",
      "npm run test*": "allow",
      "npm run build*": "allow",

      "pnpm lint*": "allow",
      "pnpm test*": "allow",
      "pnpm build*": "allow",

      "bun run lint*": "allow",
      "bun run test*": "allow",
      "bun run build*": "allow",

      "rm *": "ask",
      "sudo *": "ask",
      "chmod 777 *": "ask",
      "curl * | sh*": "ask",
      "wget * | sh*": "ask",

      "git push*": "ask",
      "docker *": "ask",
      "kubectl *": "ask"
    }
  }
}
